<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.12"
            android:text="TRILHA"
            android:textAllCaps="true"
            android:textColor="@color/trilha_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_risk_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_risk_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="Em risco"
            android:textColor="@color/trilha_streak"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_streak_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/trilha_streak"
            android:textSize="42sp"
            android:textStyle="bold"
            tools:text="7" />

        <TextView
            android:id="@+id/widget_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="6dp"
            android:textColor="@color/trilha_text"
            android:textSize="14sp"
            tools:text="dias" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_progress_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/trilha_text"
        android:textSize="13sp"
        tools:text="1/1 missões" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progress="50"
        android:progressDrawable="@drawable/widget_progress" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/trilha_text_muted"
        android:textSize="12sp"
        tools:text="Falta 1 missão" />
</LinearLayout>
