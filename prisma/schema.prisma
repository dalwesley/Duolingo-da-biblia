generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Trail {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String   @default("📖")
  order       Int      @default(0)
  unlockAfter String?
  comingSoon  Boolean  @default(false)
  color       String   @default("#6C5CE7")
  modules     Module[]
  createdAt   DateTime @default(now())
}

model Module {
  id       String    @id @default(cuid())
  trailId  String
  trail    Trail     @relation(fields: [trailId], references: [id], onDelete: Cascade)
  order    Int
  title    String
  icon     String
  missions Mission[]

  @@unique([trailId, order])
}

model Mission {
  id          String     @id @default(cuid())
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug        String     @unique
  order       Int
  title       String
  intro       String
  type        String     @default("lesson")
  xpReward    Int        @default(50)
  questions   Question[]

  @@unique([moduleId, order])
}

model Question {
  id              String @id @default(cuid())
  missionId       String
  mission         Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  order           Int
  type            String @default("multiple_choice")
  question        String
  options         String
  correctOptionId String
  feedbackCorrect String
  feedbackWrong   String
  verseRef        String?

  @@unique([missionId, order])
}
