rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin';
    }

    function isContentEditor() {
      return isAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
            && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role in ['admin', 'editor']);
    }

    function bootstrapOpen() {
      return !exists(/databases/$(database)/documents/content_meta/bootstrap_locked);
    }

    function nonNegInt(field) {
      return field is int && field >= 0 && field < 100000000;
    }

    // Cada usuário só lê/escreve o próprio progresso.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (!('steps' in request.resource.data) || nonNegInt(request.resource.data.steps))
        && (!('xp' in request.resource.data) || nonNegInt(request.resource.data.xp))
        && (!('streak' in request.resource.data) || nonNegInt(request.resource.data.streak));
    }

    // Liga semanal: qualquer autenticado lê; só o dono escreve o próprio ranking.
    // Legado flat (migração).
    match /leagues/{week}/players/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (!('xp' in request.resource.data) || nonNegInt(request.resource.data.xp))
        && (!('steps' in request.resource.data) || nonNegInt(request.resource.data.steps));
    }

    // Liga semanal por divisão (tier 0..4).
    match /leagues/{week}/tiers/{tier}/players/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (!('xp' in request.resource.data) || nonNegInt(request.resource.data.xp))
        && (!('steps' in request.resource.data) || nonNegInt(request.resource.data.steps));
    }

    // Ranking geral (passos totais): qualquer autenticado lê; cada um escreve o próprio.
    match /overallPlayers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (!('xp' in request.resource.data) || nonNegInt(request.resource.data.xp))
        && (!('steps' in request.resource.data) || nonNegInt(request.resource.data.steps));
    }

    // Ranking mensal (legado).
    match /monthlyLeagues/{month}/players/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (!('xp' in request.resource.data) || nonNegInt(request.resource.data.xp))
        && (!('steps' in request.resource.data) || nonNegInt(request.resource.data.steps));
    }

    // Salas de estudo privadas.
    match /rooms/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      match /members/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Companhias de caminhada (pares).
    match /companies/{code} {
      allow get: if isSignedIn() && (
        resource == null
        || resource.data.hostId == request.auth.uid
        || resource.data.guestId == request.auth.uid
        || resource.data.guestId == null
      );
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.hostId == request.auth.uid
            || resource.data.guestId == request.auth.uid
            || (resource.data.guestId == null
                && request.resource.data.guestId == request.auth.uid))
        && request.resource.data.hostId == resource.data.hostId;
      allow delete: if isSignedIn()
        && resource.data.hostId == request.auth.uid;
    }

    // —— Conteúdo do currículo (trilhas / perguntas / estudos) ——
    match /content_trails/{id} {
      allow read: if true;
      allow write: if isContentEditor();
    }
    match /content_bank_questions/{id} {
      allow read: if true;
      allow write: if isContentEditor();
    }
    match /content_difficulties/{id} {
      allow read: if true;
      allow write: if isContentEditor();
    }
    match /content_mission_studies/{id} {
      allow read: if true;
      allow write: if isContentEditor();
    }
    match /content_meta/{id} {
      allow read: if true;
      allow write: if isContentEditor();
    }

    // Perfis do painel admin.
    // create: só enquanto bootstrap estiver aberto (1º admin). Depois: Console / admin.
    match /admin_users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && bootstrapOpen()
        && request.resource.data.role in ['admin', 'editor'];
      allow update, delete: if isAdmin();
    }
  }
}
